<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="#2B2930"
    app:strokeColor="#49454F"
    app:strokeWidth="1dp"
    app:cardElevation="0dp"
    app:rippleColor="#44D0BCFF"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Left Accent Circle with Media Icon -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/circle_background"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/iconText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🎬"
                android:textSize="20sp" />
        </FrameLayout>

        <!-- Stream Title & Description -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/streamTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stream Title"
                android:textColor="#E6E1E5"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/streamSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Adaptive stream protocol source"
                android:textColor="#CAC4D0"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Right Side: Type Badge & Play Indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/streamTypeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_background"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="DASH"
                android:textColor="#D0BCFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="PLAY ▶"
                android:textColor="#D0BCFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
